generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  cart      Cart?
  orders    Order[]
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String
  price         Float
  stock         Int
  reserved      Int            @default(0)
  isActive      Boolean        @default(true)
  categoryId    String         @db.ObjectId
  category      Category       @relation(fields: [categoryId], references: [id])
  images        String[]
  colors        String[]       @default([])
  sizes         String[]       @default([])
  reviews       Review[]
  inventoryLogs InventoryLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Blog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  thumbnail   String?
  author      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  rating      Int
  comment     String
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @unique @db.ObjectId
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

type CartItem {
  productId String @db.ObjectId
  quantity  Int
  color     String?
  size      String?
}

model Order {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  total         Float
  discountCode  String?
  discountValue Float       @default(0)
  status        String      @default("PENDING") // PENDING, PROCESSING, SHIPPING, DELIVERED, COMPLETED, CANCELLED
  
  // Shipping & Payment Info
  fullName      String
  phoneNumber   String
  address       String
  paymentMethod String      @default("COD") // COD, ONLINE
  
  revenue       Revenue?
  createdAt     DateTime    @default(now())
}

type OrderItem {
  productId String   @db.ObjectId
  name      String
  price     Float
  quantity  Int
  color     String?
  size      String?
}

model Coupon {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  discountPercent Float
  expiryDate      DateTime
  isActive        Boolean  @default(true)
}

model Revenue {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @unique @db.ObjectId
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  createdAt DateTime @default(now())
}

enum InventoryType {
  IMPORT
  EXPORT
}

model InventoryLog {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  productId String        @db.ObjectId
  product   Product       @relation(fields: [productId], references: [id])
  type      InventoryType
  quantity  Int
  reason    String?       // E.g., "Checkout", "Manual Import", "Return"
  createdAt DateTime      @default(now())
}
